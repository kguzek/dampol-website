{
  "name": "dampol-website",
  "version": "1.0.3",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve --port=3000",
    "generate:routes": "curl -sf https://cms.modern-container.com/items/model?fields=id | jq -r '.data[] | \"/model/\\(.id)\"' > prerender-routes.txt && echo '/404' >> prerender-routes.txt",
    "generate:404": "cp dist/dampol-website/browser/404/index.html dist/dampol-website/browser/404.html",
    "build": "npm run generate:routes && ng build && npm run generate:404",
    "start": "serve dist/dampol-website/browser",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:dampol-website": "node dist/dampol-website/server/server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types:check": "tsc --noEmit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/platform-server": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/ssr": "^22.0.3",
    "@ng-web-apis/common": "^4.14.1",
    "@ng-web-apis/geolocation": "^4.14.1",
    "express": "^4.22.2",
    "flag-icons": "^6.15.0",
    "intl-tel-input": "^18.5.3",
    "ngx-cookie-service": "^22.0.0",
    "prettier": "^3.8.4",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "~22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@angular/localize": "^22.0.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/express": "^4.17.25",
    "@types/intl-tel-input": "^18.1.4",
    "@types/jasmine": "~4.6.6",
    "@types/node": "^26.0.0",
    "jasmine-core": "~4.6.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "~6.0.3"
  },
  "packageManager": "npm@11.17.0"
}
