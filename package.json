{
  "name": "dampol-website",
  "version": "1.0.3",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve --port=3000",
    "generate:routes": "curl -sf https://cms.modern-container.com/items/model?fields=id | jq -r '.data[] | \"/model/\\(.id)\"' > prerender-routes.txt && echo '/404' >> prerender-routes.txt",
    "generate:404": "cp dist/dampol-website/browser/404/index.html dist/dampol-website/browser/404.html",
    "build": "npm run generate:routes && ng build && npm run generate:404",
    "start": "serve dist/dampol-website/browser",
    "watch": "ng build --watch --configuration development",
    "serve:ssr:dampol-website": "node dist/dampol-website/server/server.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types:check": "tsc --noEmit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.5",
    "@angular/common": "^19.0.5",
    "@angular/compiler": "^19.0.5",
    "@angular/core": "^19.0.5",
    "@angular/forms": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.0.5",
    "@angular/platform-browser-dynamic": "^19.2.19",
    "@angular/platform-server": "^19.2.19",
    "@angular/router": "^19.2.19",
    "@angular/ssr": "^19.2.22",
    "@ng-web-apis/common": "^4.14.0",
    "@ng-web-apis/geolocation": "^4.14.0",
    "express": "^4.22.1",
    "flag-icons": "^6.15.0",
    "intl-tel-input": "^18.5.3",
    "ngx-cookie-service": "^19.1.2",
    "prettier": "^3.8.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.19",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "^19.0.5",
    "@angular/localize": "^19.2.19",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/express": "^4.17.25",
    "@types/intl-tel-input": "^18.1.4",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^18.19.130",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.6.3"
  }
}
